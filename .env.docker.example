# Copy this file to .env in the project root and fill in values.
# Required for: docker-compose up

# ===============================
# Django (backend)
# ===============================
DJANGO_SECRET_KEY=your-secret-key-min-50-chars

# ===============================
# Database (MySQL) – required for Docker
# ===============================
MYSQL_DATABASE=my_pharma
MYSQL_USER=mypharma
MYSQL_PASSWORD=change-me-secure-password
MYSQL_ROOT_PASSWORD=change-me-root-password

# ===============================
# Optional: override for local runs (docker-compose sets host to "mysql")
# ===============================
# MYSQL_HOST=mysql
# MYSQL_PORT=3306

# ===============================
# Frontend build args (used when building the Next.js image)
# Set these to the URL where the API will be reached FROM THE BROWSER.
# For local Docker: http://localhost:8000
# For production: https://api.yourdomain.com
# ===============================
NEXT_PUBLIC_API_URL=http://bluepillc.com:8001/api
NEXT_PUBLIC_BACKEND_URL=http://bluepillc.com:8001

# ===============================
# CORS / production
# ===============================
ALLOWED_HOSTS=localhost,127.0.0.1,backend,0.0.0.0,bluepillc.com
CORS_ALLOWED_ORIGINS=http://bluepillc.com,https://bluepillc.com
CSRF_TRUSTED_ORIGINS=http://bluepillc.com,https://bluepillc.com
